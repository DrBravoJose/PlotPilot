# 选择主 LLM provider：anthropic / openai / minimax
LLM_PROVIDER=anthropic

# aitext：Anthropic 兼容 API（与官方 SDK 一致；自建网关时设 BASE_URL）
# 与 Cursor「.claude/settings.json」里同名项对齐时，请复制到系统环境或本文件，勿提交密钥。
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=

# OpenAI 兼容接口
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o

# MiniMax（走 OpenAI 兼容接口）
# 中国大陆默认 https://api.minimaxi.com/v1
# 全球可改为 https://api.minimax.io/v1
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.5

# 与 aivideo 共用方舟凭证
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_TIMEOUT=120
ARK_REASONING_EFFORT=medium
# 代理 TLS 问题时直连
# ARK_NO_PROXY=1

# 可选默认篇幅
# AITEXT_DEFAULT_CHAPTERS=5
# AITEXT_DEFAULT_WORDS_PER_CHAPTER=2500
# AITEXT_SUMMARY_MAX_CHAPTERS=5

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/aitext.log
